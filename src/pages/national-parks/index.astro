---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import FAQ from '../../components/FAQ.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'National Parks', url: '/national-parks/' },
];

const pageTitle = 'Arizona National Parks 2026 — Grand Canyon to Saguaro';
const pageDescription = "Arizona has more national parks and monuments than almost any other state. From the Grand Canyon's mile-deep gorge to Saguaro's cactus forests, Petrified Forest's rainbow desert, and the ancient cliff dwellings of Montezuma Castle.";

const parks = [
  {
    slug: 'grand-canyon',
    name: 'Grand Canyon National Park',
    type: 'National Park',
    nearest_city: 'Flagstaff (80 mi), Williams (60 mi)',
    entrance_fee_usd: 35,
    highlight: 'One of the seven natural wonders of the world — a mile-deep gorge carved over five million years. The South Rim is open year-round and accessible by car; the North Rim opens mid-May through mid-October. Rim Trail is paved and wheelchair accessible for miles. To actually get INTO the canyon, take Bright Angel Trail (9 miles round trip to Indian Garden) or South Kaibab Trail (6 miles round trip to Cedar Ridge). Do not attempt to hike to the river and back in one day — rangers issue warnings for a reason. The inner canyon in summer reaches 110°F. The views at sunrise from Mather Point or Yavapai Observation Station are genuinely life-altering.',
    best_time: 'March–May and September–November',
    crowds: 'high',
    day_trip_from: 'Flagstaff',
    gradient: 'linear-gradient(135deg, #8B4513 0%, #D2691E 50%, #A0522D 100%)',
    tag: 'World Wonder',
  },
  {
    slug: 'saguaro',
    name: 'Saguaro National Park',
    type: 'National Park',
    nearest_city: 'Tucson (immediate — park splits the city)',
    entrance_fee_usd: 25,
    highlight: 'The only national park that splits an entire city in half. Saguaro West (Tucson Mountain District) sits in the Sonoran Desert lowlands — flatter, more accessible, with the iconic saguaro forests in every direction. Saguaro East (Rincon Mountain District) rises into the foothills with longer hiking trails and dramatically less foot traffic. The saguaro cactus grows only in the Sonoran Desert and can live 150–200 years — the giant multi-armed specimens you\'ll see here are decades older than Arizona statehood. Cactus Wren, Gila woodpeckers, and Gambel\'s quail are everywhere. Sunrise here is otherworldly, especially in late winter when the desert is green from rains.',
    best_time: 'October–April',
    crowds: 'moderate',
    day_trip_from: 'Tucson',
    gradient: 'linear-gradient(135deg, #556B2F 0%, #8FBC8F 50%, #6B8E23 100%)',
    tag: 'Iconic Desert',
  },
  {
    slug: 'petrified-forest',
    name: 'Petrified Forest National Park',
    type: 'National Park',
    nearest_city: 'Holbrook (20 mi), Winslow (55 mi)',
    entrance_fee_usd: 25,
    highlight: 'A 230-million-year-old landscape where ancient trees turned to crystal over geological time. The "wood" here is actually quartz — solid stone with grain patterns and rings still visible, in colors from purple to red to gold depending on mineral content. The park road runs 28 miles through the Painted Desert in the north (brilliant purples, reds, and mauves best at sunrise) and the main fossil wood zones in the south. Crystal Forest and Rainbow Forest have the densest concentrations of logs. The night sky here is among the darkest in the Southwest — the park holds an International Dark Sky designation. Combine with the Painted Desert Inn (historic Route 66 era building) for context on the region\'s human history.',
    best_time: 'March–May and September–November',
    crowds: 'low',
    day_trip_from: 'Flagstaff',
    gradient: 'linear-gradient(135deg, #9B2335 0%, #D4956A 50%, #7B5EA7 100%)',
    tag: 'Rainbow Desert',
  },
  {
    slug: 'organ-pipe-cactus',
    name: 'Organ Pipe Cactus National Monument',
    type: 'National Monument',
    nearest_city: 'Tucson (140 mi), Ajo (10 mi)',
    entrance_fee_usd: 25,
    highlight: 'The only place in the U.S. where the organ pipe cactus grows wild — a multi-stemmed cousin of the saguaro that looks like a pipe organ rising from the desert floor. The monument shares its southern border with Mexico and preserves the most intact stretch of the Sonoran Desert in the country. Ajo Mountain Drive (21-mile loop, unpaved but passenger-car accessible) puts you among spectacular desert scenery with zero crowds. The monument is remote — factor in a two-plus hour drive from Tucson — but the isolation is the point. Spring wildflower blooms (February–March) can be spectacular after winter rains. The monument has an International Dark Sky designation; camping here under the stars is exceptional.',
    best_time: 'November–March',
    crowds: 'low',
    day_trip_from: 'Tucson',
    gradient: 'linear-gradient(135deg, #B8860B 0%, #DAA520 50%, #8B6914 100%)',
    tag: 'Remote & Wild',
  },
  {
    slug: 'canyon-de-chelly',
    name: 'Canyon de Chelly National Monument',
    type: 'National Monument',
    nearest_city: 'Chinle (on the Navajo Nation), Flagstaff (215 mi)',
    entrance_fee_usd: 0,
    highlight: 'One of the most undervisited significant sites in the American Southwest — a 1,000-foot sandstone canyon that has been continuously inhabited for nearly 5,000 years, from Ancient Puebloans through the Navajo people who still live and farm on the canyon floor today. The monument is free to enter but the canyon floor requires a Navajo guide (authorized tours available in Chinle). The rim drives on both north and south rims are self-guided and stunning — Spider Rock Overlook drops 800 feet straight down to two sandstone spires. White House Ruin Trail is the one trail permitted without a guide, a 2.5-mile round trip to a well-preserved cliff dwelling. The Navajo Nation context matters: this is living homeland, not just a historic site.',
    best_time: 'April–October',
    crowds: 'low',
    day_trip_from: 'Flagstaff',
    gradient: 'linear-gradient(135deg, #C04000 0%, #E8854A 50%, #A0522D 100%)',
    tag: 'Free Entry',
  },
  {
    slug: 'chiricahua',
    name: 'Chiricahua National Monument',
    type: 'National Monument',
    nearest_city: 'Willcox (35 mi), Tucson (115 mi)',
    entrance_fee_usd: 20,
    highlight: 'Called the "Land of Standing-Up Rocks" by the Apaches who knew these mountains — volcanic rock formations eroded into balanced rocks, spires, and columns of rhyolite standing in dense forest at 5,000–7,500 feet elevation. A 27-million-year-old volcanic eruption created the raw material; millions of years of erosion did the sculpting. Massai Point offers the iconic panorama of rock columns disappearing into mist. The monument has 17 miles of hiking trails ranging from short loops to strenuous ridge routes. This is one of Arizona\'s genuinely off-the-radar gems — most visitors to Arizona never make it this far southeast. The Chiricahua Mountains are a famous birding destination; dozens of rare species concentrated in the sky island environment.',
    best_time: 'March–May and September–November',
    crowds: 'low',
    day_trip_from: 'Tucson',
    gradient: 'linear-gradient(135deg, #2E4A1E 0%, #5A8A3C 50%, #3D6B2A 100%)',
    tag: 'Hidden Gem',
  },
  {
    slug: 'tonto',
    name: 'Tonto Natural Bridge State Park',
    type: 'State Park (National Natural Landmark)',
    nearest_city: 'Payson (11 mi), Phoenix (100 mi)',
    entrance_fee_usd: 7,
    highlight: 'The world\'s largest natural travertine bridge — 183 feet high, 400 feet long — spanning a clear green pool in Pine Creek Canyon. Travertine (calcium carbonate deposited by mineral springs) built up over thousands of years to create this arch, which now frames a waterfall and swimming hole beneath it. The park is small and the hike down to the bridge is steep but short (about 0.5 miles). Swimming under the bridge is permitted and deeply satisfying. This is an extraordinary geological feature that most Arizonans have never seen — only 12,000 people a year visit, compared to millions at the Grand Canyon 3 hours north. Day trip from Phoenix makes for an excellent escape from the heat valley in summer (elevation 4,500 feet).',
    best_time: 'April–October',
    crowds: 'low',
    day_trip_from: 'Phoenix',
    gradient: 'linear-gradient(135deg, #1B6E6E 0%, #2EAAAA 50%, #137070 100%)',
    tag: 'World\'s Largest',
  },
  {
    slug: 'montezuma-castle',
    name: 'Montezuma Castle National Monument',
    type: 'National Historical Park',
    nearest_city: 'Camp Verde (5 mi), Sedona (25 mi), Phoenix (90 mi)',
    entrance_fee_usd: 10,
    highlight: 'A 20-room cliff dwelling built into a natural limestone alcove 90 feet above Beaver Creek — one of the best-preserved prehistoric structures in North America. The Sinagua people built and occupied Montezuma Castle from approximately 1100 to 1425 CE before mysteriously abandoning it. The name is completely wrong — Spanish explorers named it after the Aztec emperor with no historical basis; the Sinagua had no connection to the Aztecs. You can\'t enter the dwelling but the paved half-mile trail along the creek gives excellent views. The nearby Montezuma Well (7 miles north, free) is a limestone sink fed by 1.5 million gallons of spring water daily — equally fascinating and far less visited. Combine both in a half-day stop between Phoenix and Sedona.',
    best_time: 'October–May',
    crowds: 'moderate',
    day_trip_from: 'Sedona',
    gradient: 'linear-gradient(135deg, #8B4513 0%, #CD853F 50%, #A0522D 100%)',
    tag: 'Ancient History',
  },
];

const crowdColor = { low: '#2E7D32', moderate: '#F57F17', high: '#C62828' };
const crowdLabel = { low: 'Low crowds', moderate: 'Moderate crowds', high: 'High crowds' };
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  pageType="destination"
  breadcrumbs={breadcrumbs}
>

<style>
  .parks-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    padding: 0 var(--space-6) 60px;
    overflow: hidden;
    background: linear-gradient(135deg, #4A1A00 0%, #8B4513 50%, #6B3410 100%);
  }

  .parks-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
  }

  .parks-hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(74, 26, 0, 0.92) 0%, rgba(74, 26, 0, 0.35) 60%, transparent 100%);
  }

  .parks-hero-content {
    position: relative;
    z-index: 2;
    max-width: 780px;
  }

  .parks-hero-eyebrow {
    font-size: 0.72rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #FFA726;
    margin-bottom: var(--space-3);
  }

  .parks-hero-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: var(--weight-bold);
    color: #fff;
    line-height: 1.15;
    margin: 0 0 var(--space-4);
  }

  .parks-hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.6;
    margin: 0 0 var(--space-6);
    max-width: 620px;
  }

  .parks-hero-meta {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .parks-hero-meta-item { display: flex; flex-direction: column; gap: 2px; }
  .parks-hero-meta-label { font-size: 0.68rem; font-weight: var(--weight-semibold); text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.5); }
  .parks-hero-meta-value { font-size: 1.4rem; font-weight: var(--weight-bold); color: #fff; }

  .parks-personal { padding-block: var(--space-8); }
  .parks-personal-quote {
    max-width: 740px;
    margin: 0 auto;
    padding: var(--space-6) var(--space-8);
    border-left: 4px solid #D2691E;
    background: var(--color-sky, #fff8f3);
    border-radius: 0 12px 12px 0;
  }
  .parks-personal-quote p { font-size: var(--text-body, 1.05rem); color: var(--color-heading, #1a2332); line-height: 1.7; font-style: italic; margin-bottom: var(--space-3); }
  .parks-personal-quote cite { font-size: 0.85rem; color: #D2691E; font-weight: var(--weight-semibold); font-style: normal; }

  .parks-section { padding: var(--space-6) 0 var(--space-10); }
  .parks-section-heading { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: var(--weight-bold); color: var(--color-deep-night, #1a2332); margin: 0 0 var(--space-2); text-align: center; }
  .parks-section-sub { font-size: 1rem; color: var(--color-slate, #5a6a7a); text-align: center; margin: 0 0 var(--space-8); }

  .parks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-6);
  }

  .park-card {
    border-radius: 20px;
    overflow: hidden;
    background: var(--color-white, #fff);
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .park-card:hover { transform: translateY(-6px); box-shadow: 0 12px 40px rgba(0,0,0,0.12); }

  .park-card-header {
    padding: var(--space-5) var(--space-5) var(--space-4);
    min-height: 140px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .park-card-tag { display: inline-block; font-size: 0.65rem; font-weight: var(--weight-bold); text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.9); background: rgba(255,255,255,0.18); backdrop-filter: blur(4px); padding: 3px 10px; border-radius: 20px; margin-bottom: var(--space-2); width: fit-content; }
  .park-card-name { font-size: 1.2rem; font-weight: var(--weight-bold); color: #fff; line-height: 1.3; margin: 0 0 4px; }
  .park-card-type { font-size: 0.78rem; color: rgba(255,255,255,0.75); font-weight: var(--weight-medium); }

  .park-card-body { padding: var(--space-4) var(--space-5) var(--space-5); flex: 1; display: flex; flex-direction: column; gap: var(--space-3); }

  .park-card-meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2) var(--space-4);
    padding: var(--space-3);
    background: rgba(0,0,0,0.03);
    border-radius: 10px;
  }
  .park-meta-item { display: flex; flex-direction: column; gap: 1px; }
  .park-meta-label { font-size: 0.63rem; font-weight: var(--weight-bold); text-transform: uppercase; letter-spacing: 0.09em; color: var(--color-slate, #5a6a7a); }
  .park-meta-value { font-size: 0.82rem; font-weight: var(--weight-semibold); color: var(--color-heading, #1a2332); }

  .park-crowd-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.75rem;
    font-weight: var(--weight-semibold);
    padding: 3px 10px;
    border-radius: 20px;
    width: fit-content;
  }
  .park-crowd-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }

  .park-card-desc { font-size: 0.87rem; color: var(--color-body, #3d4d5e); line-height: 1.68; flex: 1; }

  .park-card-nearest { font-size: 0.78rem; color: var(--color-slate, #5a6a7a); padding-top: var(--space-2); border-top: 1px solid rgba(0,0,0,0.06); }
  .park-card-nearest strong { color: var(--color-heading, #1a2332); }

  /* Planning section */
  .parks-planning { padding: var(--space-8) 0; background: linear-gradient(135deg, #4A1A00 0%, #8B4513 100%); }
  .parks-planning-inner { max-width: 860px; margin: 0 auto; padding: 0 var(--space-6); }
  .parks-planning-heading { font-size: clamp(1.3rem, 3vw, 1.9rem); font-weight: var(--weight-bold); color: #fff; margin: 0 0 var(--space-4); text-align: center; }
  .parks-planning-intro { font-size: 0.95rem; color: rgba(255,255,255,0.78); line-height: 1.7; text-align: center; max-width: 680px; margin: 0 auto var(--space-7); }

  .parks-routes { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: var(--space-4); }
  .parks-route-card { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12); border-radius: 16px; padding: var(--space-4) var(--space-5); }
  .parks-route-hub { font-size: 0.68rem; font-weight: var(--weight-bold); text-transform: uppercase; letter-spacing: 0.1em; color: #FFA726; margin-bottom: var(--space-2); }
  .parks-route-title { font-size: 1rem; font-weight: var(--weight-bold); color: #fff; margin-bottom: var(--space-2); }
  .parks-route-stops { font-size: 0.82rem; color: rgba(255,255,255,0.72); line-height: 1.65; }
  .parks-route-stops li { margin-bottom: 4px; }

  .parks-pass-banner { margin-top: var(--space-7); background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 14px; padding: var(--space-4) var(--space-6); display: flex; align-items: flex-start; gap: var(--space-4); }
  .parks-pass-icon { font-size: 2rem; flex-shrink: 0; }
  .parks-pass-text h3 { font-size: 1rem; font-weight: var(--weight-bold); color: #fff; margin: 0 0 var(--space-1); }
  .parks-pass-text p { font-size: 0.85rem; color: rgba(255,255,255,0.72); line-height: 1.6; margin: 0; }

  /* Tips / Scott says */
  .parks-tips { padding: var(--space-8) 0 var(--space-10); }
  .parks-tips-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: var(--space-4); margin-top: var(--space-6); }
  .parks-tip-card { background: var(--color-white, #fff); border: 1px solid rgba(0,0,0,0.07); border-radius: 16px; padding: var(--space-4) var(--space-5); box-shadow: 0 2px 12px rgba(0,0,0,0.05); }
  .parks-tip-icon { font-size: 1.5rem; margin-bottom: var(--space-2); }
  .parks-tip-title { font-size: 0.9rem; font-weight: var(--weight-bold); color: var(--color-heading, #1a2332); margin-bottom: var(--space-2); }
  .parks-tip-text { font-size: 0.82rem; color: var(--color-body, #3d4d5e); line-height: 1.62; }

  /* CTA */
  .parks-cta-section { padding: var(--space-8) 0; }
  .parks-cta-card { background: linear-gradient(135deg, #4A1A00 0%, #8B4513 100%); border-radius: 20px; padding: var(--space-8) var(--space-6); text-align: center; color: #fff; }
  .parks-cta-heading { font-size: clamp(1.3rem, 3vw, 1.8rem); font-weight: var(--weight-bold); margin: 0 0 var(--space-3); color: #fff; }
  .parks-cta-text { font-size: 1rem; color: rgba(255,255,255,0.75); max-width: 520px; margin: 0 auto var(--space-5); line-height: 1.6; }
  .parks-cta-button { display: inline-block; background: #FFA726; color: #fff; font-size: 0.9rem; font-weight: var(--weight-semibold); padding: 12px 28px; border-radius: 40px; text-decoration: none; transition: background 0.2s ease, transform 0.2s ease; }
  .parks-cta-button:hover { background: #E65100; transform: translateY(-2px); }

  /* Cross-links */
  .parks-crosslinks { padding: 0 0 var(--space-10); }
  .parks-crosslinks-heading { font-size: 1.1rem; font-weight: var(--weight-bold); color: var(--color-deep-night, #1a2332); text-align: center; margin: 0 0 var(--space-4); }
  .parks-crosslinks-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-4); max-width: 640px; margin: 0 auto; }
  .parks-crosslink-card { display: flex; flex-direction: column; align-items: center; gap: var(--space-2); padding: var(--space-5) var(--space-4); background: var(--color-white, #fff); border: 1px solid rgba(0,0,0,0.06); border-radius: 16px; text-decoration: none; color: inherit; text-align: center; transition: transform 0.3s ease, box-shadow 0.3s ease; }
  .parks-crosslink-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
  .parks-crosslink-icon { font-size: 1.8rem; }
  .parks-crosslink-label { font-size: 0.95rem; font-weight: var(--weight-bold); color: var(--color-deep-night, #1a2332); }
  .parks-crosslink-desc { font-size: 0.78rem; color: var(--color-slate, #5a6a7a); line-height: 1.4; }

  @media (max-width: 640px) {
    .parks-crosslinks-grid { grid-template-columns: 1fr; }
    .parks-grid { grid-template-columns: 1fr; }
    .parks-hero { padding: 0 var(--space-4) 40px; min-height: 55vh; }
    .parks-hero-meta { gap: var(--space-4); }
    .park-card-meta { grid-template-columns: 1fr; }
    .parks-pass-banner { flex-direction: column; }
  }

  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.visible { opacity: 1; transform: none; }
</style>

  <!-- Hero -->
  <header class="parks-hero">
    <video class="parks-hero-video" autoplay muted loop playsinline preload="metadata">
      <source src="/videos/pillar/national-parks-hero.mp4" type="video/mp4" />
    </video>
    <div class="parks-hero-gradient"></div>
    <div class="parks-hero-content">
      <p class="parks-hero-eyebrow">Arizona National Parks & Monuments</p>
      <h1 class="parks-hero-title">Arizona National Parks 2026</h1>
      <p class="parks-hero-subtitle">From the Grand Canyon's mile-deep gorge to Saguaro's towering cactus forests, Petrified Forest's rainbow desert, and Canyon de Chelly's living canyon — Arizona protects more natural and cultural wonders than almost anywhere on earth.</p>
      <div class="parks-hero-meta">
        <div class="parks-hero-meta-item">
          <span class="parks-hero-meta-label">Parks & Monuments</span>
          <span class="parks-hero-meta-value">8</span>
        </div>
        <div class="parks-hero-meta-item">
          <span class="parks-hero-meta-label">Best Season</span>
          <span class="parks-hero-meta-value">Mar – May</span>
        </div>
        <div class="parks-hero-meta-item">
          <span class="parks-hero-meta-label">America the Beautiful</span>
          <span class="parks-hero-meta-value">$80/yr</span>
        </div>
      </div>
    </div>
  </header>

  <div class="container-content">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- Personal Intro -->
  <section class="parks-personal reveal">
    <div class="container-content">
      <blockquote class="parks-personal-quote">
        <p>Arizona has more federally protected land than any state except Alaska and California, and it shows. You can spend an entire week doing nothing but national parks and monuments and still leave things undone. The Grand Canyon gets 6 million visitors a year — it deserves every one. But the parks that move me most are the ones barely anyone visits: Chiricahua in the far southeast, with its columns of standing rock disappearing into pine forest; Organ Pipe Cactus down near the Mexican border, where you can hike all day without seeing another person; Canyon de Chelly on the Navajo Nation, where families still farm the canyon floor beneath cliff dwellings that are a thousand years old. Buy the America the Beautiful Pass the moment you arrive. It pays for itself at the Grand Canyon alone.</p>
        <cite>— Scott Murray, Discover Arizona</cite>
      </blockquote>
    </div>
  </section>

  <!-- Park Cards -->
  <section class="parks-section reveal">
    <div class="container-content">
      <h2 class="parks-section-heading">Arizona's National Parks & Monuments</h2>
      <p class="parks-section-sub">Eight world-class protected areas — from canyon floors to cactus forests to ancient cliff dwellings.</p>
      <div class="parks-grid">
        {parks.map((park) => (
          <div class="park-card reveal">
            <div class="park-card-header" style={`background: ${park.gradient};`}>
              {park.tag && <span class="park-card-tag">{park.tag}</span>}
              <h3 class="park-card-name">{park.name}</h3>
              <div class="park-card-type">{park.type}</div>
            </div>
            <div class="park-card-body">
              <div class="park-card-meta">
                <div class="park-meta-item">
                  <span class="park-meta-label">Entrance Fee</span>
